# websites-for-all just for reference - don't check it in!
websites-for-all

# scratch / test output
.tmp/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
.env

# Django
db.sqlite3
static/
media/
*.log
local_settings.py
wagtail_wtr/settings/local.py

# Node
node_modules/
npm-debug.log*

# Frontend build output (generated by make build / make build-prod)
# Keep .gitkeep files so empty dirs are tracked; ignore everything else.
static_compiled/css/main.css
static_compiled/js/
static_compiled/fonts/
static_compiled/images/

# Provisioning credentials (written by bin/provision.sh — never commit)
.env.provision.*

# Large media files — never commit video/audio to the repo
*.mkv
*.mp4
*.mov
*.avi
*.webm

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
.coverage
htmlcov/
