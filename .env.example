# wagtail-wtr environment variables
# Copy this file to .env (gitignored) and fill in your values for local overrides.
# In production (Render, etc.) set these as environment variables directly.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Django secret key — generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=

# Full PostgreSQL connection string (set automatically on Render via render.yaml)
DATABASE_URL=

# Comma-separated list of allowed hostnames (e.g. mysite.onrender.com,mysite.org)
ALLOWED_HOSTS=

# Full public URL of the site used by the Wagtail admin (no trailing slash)
# Example: https://mysite.onrender.com
WAGTAILADMIN_BASE_URL=

# Django settings module
DJANGO_SETTINGS_MODULE=wagtail_wtr.settings.production

# ---------------------------------------------------------------------------
# AWS S3 storage (optional but strongly recommended for production)
# When set, BOTH user-uploaded media (images, documents) AND collected static
# files (CSS, JS, fonts) are stored in S3 under separate prefixes:
#   {bucket}/media/   — user uploads
#   {bucket}/static/  — compiled static assets
# When S3 is configured, collectstatic runs in Render's preDeployCommand (render.yaml)
# before the container starts. Without S3, it runs in start.sh (WhiteNoise path).
# Omit AWS_STORAGE_BUCKET_NAME to serve static files via WhiteNoise and store
# media on the local filesystem instead.
# WARNING: Render's Docker containers use ephemeral disks — any media stored
# locally will be lost on every new deploy. Configure S3 for production use.
# ---------------------------------------------------------------------------

AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: CloudFront or custom domain for public media URLs
AWS_S3_CUSTOM_DOMAIN=

# ---------------------------------------------------------------------------
# SMTP email (optional)
# When EMAIL_HOST is set, Django sends mail via SMTP.
# Omit EMAIL_HOST to fall back to the console backend (emails printed to logs).
# Compatible with Mailgun, AWS SES, Postmark, or any standard SMTP provider.
# ---------------------------------------------------------------------------

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# STARTTLS (port 587, most common): EMAIL_USE_TLS=true, EMAIL_USE_SSL=false
# Implicit SSL (port 465): EMAIL_USE_TLS=false, EMAIL_USE_SSL=true
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Cloudflare cache invalidation (optional)
# Omit both vars to disable. See README for setup instructions.
# ---------------------------------------------------------------------------

CLOUDFLARE_BEARER_TOKEN=
CLOUDFLARE_ZONE_ID=

# ---------------------------------------------------------------------------
# Gunicorn
# ---------------------------------------------------------------------------

WEB_CONCURRENCY=4
# Worker timeout in seconds. Increase for slow responses (default: 120).
GUNICORN_TIMEOUT=120
